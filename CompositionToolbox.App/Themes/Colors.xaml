<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Shared row background -->
    <SolidColorBrush x:Key="App.RowBackgroundBrush" Color="#1E1E1E" />

    <!-- Transform Log palette -->
    <SolidColorBrush x:Key="App.TransformLog.HeaderBackgroundBrush" Color="#2B2B2B" />
    <SolidColorBrush x:Key="App.TransformLog.HeaderBorderBrush" Color="#3C3C3C" />
    <SolidColorBrush x:Key="App.TransformLog.RowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="App.TransformLog.RowBorderBrush" Color="#3C3C3C" />
    <SolidColorBrush x:Key="App.TransformLog.RowSelectedBrush" Color="#3A3D41" />
    <SolidColorBrush x:Key="App.TransformLog.RowTextBrush" Color="#929193" />
    <SolidColorBrush x:Key="App.TransformLog.RowSelectedTextBrush" Color="#FFFFFF" />
</ResourceDictionary>
