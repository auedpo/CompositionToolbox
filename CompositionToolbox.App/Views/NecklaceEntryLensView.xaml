<UserControl x:Class="CompositionToolbox.App.Views.NecklaceEntryLensView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SizeChanged="NecklaceEntryLensView_SizeChanged">
    <UserControl.Resources>
        <SolidColorBrush x:Key="NecklaceStrokeBrush" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}" />
        <SolidColorBrush x:Key="NecklacePanelBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
        <Style x:Key="NecklaceNodeStyle" TargetType="Ellipse">
            <Setter Property="Stroke" Value="{StaticResource NecklaceStrokeBrush}" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="Fill" Value="{StaticResource NecklacePanelBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <EventSetter Event="MouseLeftButtonDown" Handler="NecklaceNode_MouseLeftButtonDown" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource NecklaceStrokeBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="Back" Command="{Binding BackspaceCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ClearCommand}" />
        <KeyBinding Key="Enter" Command="{Binding CommitCommand}" />
    </UserControl.InputBindings>
    <Border Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Necklace Entry" FontWeight="Bold" Margin="0,0,0,8" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Modulus:" Margin="0,0,6,0" />
                <TextBlock Text="{Binding Modulus}" />
                <TextBlock Text="Cardinality:" Margin="12,0,6,0" />
                <TextBlock Text="{Binding Cardinality}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Order:" FontWeight="Bold" Margin="0,0,6,0" />
                <TextBlock Text="{Binding OrderDisplay}" FontFamily="{DynamicResource App.MonoFontFamily}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Clear" Command="{Binding ClearCommand}" Margin="0,0,6,0" />
                <Button Content="Backspace" Command="{Binding BackspaceCommand}" Margin="0,0,6,0" />
                <Button Content="Commit" Command="{Binding CommitCommand}" />
            </StackPanel>

            <Border Grid.Row="4"
                    x:Name="NecklaceFrame"
                    BorderBrush="{DynamicResource App.PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="6"
                    Background="{StaticResource NecklacePanelBrush}"
                    HorizontalAlignment="Stretch">
                <Grid x:Name="NecklaceHost"
                      Height="360"
                      Width="{Binding ActualWidth, ElementName=Root}"
                      HorizontalAlignment="Stretch"
                      Loaded="NecklaceHost_Loaded"
                      SizeChanged="NecklaceHost_SizeChanged">
                    <Canvas x:Name="NecklaceCanvas"
                            Width="{Binding ActualWidth, ElementName=NecklaceHost}"
                            Height="{Binding ActualHeight, ElementName=NecklaceHost}"
                            Background="Transparent"
                            ClipToBounds="True"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Ellipse Width="{Binding CircleDiameter}"
                                 Height="{Binding CircleDiameter}"
                                 Canvas.Left="{Binding CircleLeft}"
                                 Canvas.Top="{Binding CircleTop}"
                                 Stroke="{StaticResource NecklaceStrokeBrush}"
                                 StrokeThickness="1"
                                 Panel.ZIndex="0" />
                        <Polyline Points="{Binding PolylinePoints}"
                                  Stroke="{StaticResource NecklaceStrokeBrush}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Panel.ZIndex="1" />
                        <ItemsControl ItemsSource="{Binding Nodes}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Panel.ZIndex" Value="2" />
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    <Setter Property="Panel.ZIndex" Value="3" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Style="{StaticResource NecklaceNodeStyle}"
                                             Width="{Binding Diameter}"
                                             Height="{Binding Diameter}">
                                        <Ellipse.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.TogglePcCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding Pc}" />
                                        </Ellipse.InputBindings>
                                        <Ellipse.ToolTip>
                                            <TextBlock Text="{Binding Pc}" />
                                        </Ellipse.ToolTip>
                                    </Ellipse>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Grid>
            </Border>

            <TextBlock Grid.Row="5"
                       Text="Click nodes to build an ordered traversal. Backspace removes the last entry."
                       FontStyle="Italic"
                       Margin="0,6,0,0" />
        </Grid>
    </Border>
</UserControl>
