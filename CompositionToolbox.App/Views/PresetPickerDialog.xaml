<Window x:Class="CompositionToolbox.App.Views.PresetPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CompositionToolbox.App.Converters"
        xmlns:views="clr-namespace:CompositionToolbox.App.Views"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework" xmlns:local="clr-namespace:CompositionToolbox.App.Views.Behaviors"
        Title="Preset Picker"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI"
        FlowDirection="LeftToRight">
    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#3C3C3C" />
        <Style x:Key="FilterListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2F3B48" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B2F33" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#A0A0A0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PresetGridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Visibility" Value="Visible" />
            <EventSetter Event="Click" Handler="ResultsHeader_Click" />
        </Style>
        <Style x:Key="PresetListViewStyle" TargetType="ListView">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource App.RowBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#2B2B2B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <DockPanel>
                                <GridViewHeaderRowPresenter DockPanel.Dock="Top"
                                                            Columns="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=View.Columns}"
                                                            ColumnHeaderContainerStyle="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=View.ColumnHeaderContainerStyle}" />
                                <ScrollViewer Focusable="False"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                              CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetGridItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <GridViewRowPresenter Columns="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=View.Columns}"
                                                  Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A3D41" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#323438" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FilterColumn" Width="180" MinWidth="140" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="PreviewColumn" Width="340" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Grid.ColumnSpan="5"
                 Margin="0,0,0,8"
                 Background="{DynamicResource {x:Static sys:SystemColors.WindowBrushKey}}"
                 Foreground="{DynamicResource {x:Static sys:SystemColors.ControlTextBrushKey}}"
                 BorderBrush="{DynamicResource {x:Static sys:SystemColors.ActiveBorderBrushKey}}"
                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 FlowDirection="LeftToRight"
                 TextAlignment="Left"
                 PreviewKeyDown="SearchBox_PreviewKeyDown" />

        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  Grid.Column="2"
                  Style="{StaticResource PresetListViewStyle}"
                  ItemsSource="{Binding Results}"
                  SelectedItem="{Binding SelectedPreset}"
                  local:ListViewLazyVmLoader.EnableLazyVmLoading="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  MouseDoubleClick="ResultsList_MouseDoubleClick"
                  SelectionChanged="ResultsList_SelectionChanged"
                  ItemContainerStyle="{StaticResource PresetGridItemStyle}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.View>
                <GridView AllowsColumnReorder="True" ColumnHeaderContainerStyle="{StaticResource PresetGridHeaderStyle}">
                    <GridViewColumn Header="Prime form" Width="320">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PrimeFormDisplay}" Foreground="LightGray" FontFamily="Consolas" Padding="6,4" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="k" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="k" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CardinalityValue}" Foreground="LightGray" HorizontalAlignment="Center" Padding="6,4" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Name" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Id}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Padding="6,4" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC1" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC1" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IC1}" Foreground="LightGray" HorizontalAlignment="Center" Padding="6,4" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC2" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC2" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC2}" Foreground="LightGray" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC3" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC3" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC3}" Foreground="LightGray" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC4" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC4" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC4}" Foreground="LightGray" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC5" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC5" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC5}" Foreground="LightGray" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC6" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="IC6" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC6}" Foreground="LightGray" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Fav" Width="40">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Fav" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding FavoriteIcon}"
                                        Command="{Binding ToggleFavoriteCommand}"
                                        Style="{StaticResource StarButtonStyle}"
                                        Width="28"
                                        Height="24"
                                        Margin="4"
                                        HorizontalAlignment="Center"
                                        ToolTip="Toggle favorite"
                                        Focusable="False" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="1"
                Grid.Column="4"
                Background="#252526"
                Padding="8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedPreset.Id}" Foreground="White" FontWeight="Bold" />
                    <Button DataContext="{Binding SelectedPreset}"
                            Content="{Binding FavoriteIcon}"
                            Command="{Binding ToggleFavoriteCommand}"
                            Style="{StaticResource StarButtonStyle}"
                            Width="28"
                            Height="24"
                            Margin="8,0,0,0"
                            ToolTip="Toggle favorite"
                            Focusable="False" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedPreset.PrimeFormDisplay}" Foreground="LightGray" FontFamily="Consolas" Margin="0,4,0,0" />
                <TextBlock Text="{Binding SelectedPreset.CardinalityDisplay}" Foreground="LightGray" Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <RadioButton Content="Chord"
                                 IsChecked="{Binding SelectedNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Chord}"
                                 GroupName="PresetNotationMode"
                                 Margin="0,0,8,0"
                                 Focusable="False" />
                    <RadioButton Content="Sequence"
                                 IsChecked="{Binding SelectedNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sequence}"
                                 GroupName="PresetNotationMode"
                                 Focusable="False" />
                    <Button Content="Play" Command="{Binding PlayCommand}" Margin="12,0,0,0" Focusable="False" />
                </StackPanel>
                <views:NotationView x:Name="PreviewNotation" Height="220" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#252526"
                Padding="8"
                Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Cardinality" Foreground="White" FontWeight="Bold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding CardinalityOptions}"
                         SelectedValuePath="Value"
                         SelectedValue="{Binding SelectedCardinality}"
                         ItemContainerStyle="{StaticResource FilterListItemStyle}"
                         SelectionChanged="CardinalityList_SelectionChanged"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border BorderBrush="{StaticResource GridLineBrush}" BorderThickness="0,1,0,0" Margin="0,8,0,8" />

                <TextBlock Text="Favorites" Foreground="White" FontWeight="Bold" Margin="0,0,0,4" />
                <CheckBox Content="Only favorites"
                          IsChecked="{Binding ShowFavoritesOnly}"
                          Checked="FavoritesOnly_Checked"
                          Unchecked="FavoritesOnly_Checked" />
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#2B2B2B"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />

        <GridSplitter Grid.Row="1"
                      Grid.Column="3"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#2B2B2B"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />
    </Grid>
</Window>
