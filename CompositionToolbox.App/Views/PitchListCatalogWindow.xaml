<Window x:Class="CompositionToolbox.App.Views.PitchListCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="PitchList Catalog"
        Width="860"
        Height="560"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FilterListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PresetGridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="{DynamicResource App.ListBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        </Style>
        <Style x:Key="PresetListViewStyle" TargetType="ListView">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource App.ListBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <DockPanel>
                                <GridViewHeaderRowPresenter DockPanel.Dock="Top"
                                                            Columns="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=View.Columns}"
                                                            ColumnHeaderContainerStyle="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=View.ColumnHeaderContainerStyle}" />
                                <ScrollViewer Focusable="False"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                              CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetGridItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource App.ListBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <GridViewRowPresenter Columns="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=View.Columns}"
                                                  Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource App.DividerBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0"
                 Grid.ColumnSpan="3"
                 Margin="0,0,0,8"
                 VerticalContentAlignment="Center"
                 Height="28"
                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

        <Border Grid.Row="1" Grid.Column="0" Padding="8,4,8,4">
            <StackPanel>
                <TextBlock Text="Filters" FontWeight="Bold" Margin="0,0,0,6" />
                <TextBlock Text="Cardinality" FontWeight="Bold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding CardinalityOptions}"
                         SelectedValuePath="Value"
                         SelectedValue="{Binding SelectedCardinality}"
                         ItemContainerStyle="{StaticResource FilterListItemStyle}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,1,0,0" Margin="0,8,0,8" />
                <TextBlock Text="Favorites" FontWeight="Bold" Margin="0,0,0,4" />
                <CheckBox Content="Only favorites" IsChecked="{Binding ShowFavoritesOnly}" />
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource App.DividerBrush}"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />

        <ListView Grid.Row="1"
                  Grid.Column="2"
                  Style="{StaticResource PresetListViewStyle}"
                  ItemsSource="{Binding Results}"
                  SelectedItem="{Binding SelectedPreset}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource PresetGridItemStyle}">
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource PresetGridHeaderStyle}">
                    <GridViewColumn Header="Prime form" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding PrimeFormDisplay}" FontFamily="Consolas" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding NameDisplay}" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Cardinality" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding CardinalityValue}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC1" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC1}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC2" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC2}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC3" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC3}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC4" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC4}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC5" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC5}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IC6" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource App.DividerBrush}" BorderThickness="0,0,1,0" Padding="6,4">
                                    <TextBlock Text="{Binding IC6}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Favorite" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="4">
                                    <Button Content="{Binding FavoriteIcon}"
                                            Command="{Binding ToggleFavoriteCommand}"
                                            Style="{StaticResource StarButtonStyle}"
                                            Width="28"
                                            Height="24"
                                            HorizontalAlignment="Center"
                                            ToolTip="Toggle favorite"
                                            Focusable="False" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
