<!-- Purpose: Markup for the Pitch List Catalog Window view wiring its layout and bindings. -->

<Window x:Class="CompositionToolbox.App.Views.PitchListCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CompositionToolbox.App.Views.Behaviors"
        xmlns:converters="clr-namespace:CompositionToolbox.App.Converters"
        xmlns:views="clr-namespace:CompositionToolbox.App.Views"
        Title="PitchList Catalog"
        Width="860"
        Height="560"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.App.Background}"
        Foreground="{DynamicResource Brush.Text.Primary}">
    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="PreviewColumn" Width="340" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0"
                 Grid.ColumnSpan="3"
                 Margin="0,0,0,8"
                 VerticalContentAlignment="Center"
                 Height="28"
                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

        <Border Grid.Row="1" Grid.Column="0" Padding="8,4,8,4">
            <StackPanel>
                <TextBlock Text="Filters" FontWeight="Bold" Margin="0,0,0,6" />
                <TextBlock Text="Cardinality" FontWeight="Bold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding CardinalityOptions}"
                         SelectedValuePath="Value"
                         SelectedValue="{Binding SelectedCardinality}"
                         ItemContainerStyle="{DynamicResource FilterListItemStyle}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border BorderBrush="{DynamicResource Brush.Surface.Border}" BorderThickness="0,1,0,0" Margin="0,8,0,8" />
                <TextBlock Text="Favorites" FontWeight="Bold" Margin="0,0,0,4" />
                <CheckBox Content="Only favorites" IsChecked="{Binding ShowFavoritesOnly}" />
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource Brush.Surface.Border}"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />

        <DataGrid x:Name="ResultsGrid" Grid.Row="1"
                  Grid.Column="2"
                  ItemsSource="{Binding Results}"
                  SelectedItem="{Binding SelectedPreset}"
                  local:DataGridLazyVmLoader.EnableLazyVmLoading="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  AutoGenerateColumns="False"
                  RowHeight="32"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                  PreviewKeyDown="ResultsGrid_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Prime form" Binding="{Binding PrimeFormDisplay}" Width="200" IsReadOnly="True" />
                <DataGridTextColumn Header="Name" Binding="{Binding NameDisplay}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Cardinality" Binding="{Binding CardinalityValue}" Width="90" IsReadOnly="True" />
                <DataGridTextColumn Header="IC1" Binding="{Binding IC1}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="IC2" Binding="{Binding IC2}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="IC3" Binding="{Binding IC3}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="IC4" Binding="{Binding IC4}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="IC5" Binding="{Binding IC5}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="IC6" Binding="{Binding IC6}" Width="40" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Favorite" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding FavoriteIcon}"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    Style="{DynamicResource StarButtonStyle}"
                                    Width="28"
                                    Height="24"
                                    Margin="4"
                                    HorizontalAlignment="Center"
                                    ToolTip="Toggle favorite"
                                    Focusable="False" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1"
                Grid.Column="4"
                Background="{DynamicResource Brush.Surface.Background}"
                Padding="8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedPreset.Id}" FontWeight="Bold" />
                    <Button DataContext="{Binding SelectedPreset}"
                            Content="{Binding FavoriteIcon}"
                            Command="{Binding ToggleFavoriteCommand}"
                            Style="{DynamicResource StarButtonStyle}"
                            Width="28"
                            Height="24"
                            Margin="8,0,0,0"
                            ToolTip="Toggle favorite"
                            Focusable="False" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedPreset.PrimeFormDisplay}" Foreground="{DynamicResource Brush.Text.Secondary}" FontFamily="{DynamicResource App.MonoFontFamily}" Margin="0,4,0,0" />
                <TextBlock Text="{Binding SelectedPreset.CardinalityDisplay}" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <RadioButton Content="Chord"
                                 IsChecked="{Binding SelectedNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Chord}"
                                 GroupName="PresetNotationMode"
                                 Margin="0,0,8,0"
                                 Focusable="False" />
                    <RadioButton Content="Sequence"
                                 IsChecked="{Binding SelectedNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sequence}"
                                 GroupName="PresetNotationMode"
                                 Focusable="False" />
                    <Button Content="Play" Command="{Binding PlayCommand}" Margin="12,0,0,0" Focusable="False" />
                </StackPanel>
                <views:NotationView x:Name="PreviewNotation" Height="220" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
