<Window x:Class="CompositionToolbox.App.Views.InspectorNotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CompositionToolbox.App.Views"
        Title="Inspector Notation"
        Width="960"
        Height="420"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="HeaderText" Foreground="White" FontWeight="Bold" />
        </StackPanel>
        <views:NotationView x:Name="ExpandedNotation" Grid.Row="1" />
    </Grid>
</Window>
