<!-- Purpose: Layout for the primary application shell window, binding the main view model and menu commands. -->

<Window x:Class="CompositionToolbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CompositionToolbox.App.ViewModels"
        xmlns:views="clr-namespace:CompositionToolbox.App.Views"
        xmlns:converters="clr-namespace:CompositionToolbox.App.Converters"
        xmlns:local="clr-namespace:CompositionToolbox.App"
        Title="Composition Toolbox" Height="720" Width="1100"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.App.Background}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.ShowTransformLogDetailsCommand}"
                        Executed="TransformLogDetails_Executed"
                        CanExecute="TransformLogDetails_CanExecute" />
    </Window.CommandBindings>

    <Window.Resources>
        <converters:TransformLogEntryConverter x:Key="TransformLogEntryConverter" />
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        </Style>
        <Style x:Key="RowSplitterPreviewStyle" TargetType="Control">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Rectangle Fill="{DynamicResource Brush.Canvas.GridLine}"
                                   Height="2"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LeftRowSplitterPreviewStyle" TargetType="Control" BasedOn="{StaticResource RowSplitterPreviewStyle}">
            <Setter Property="Width" Value="{Binding ActualWidth, ElementName=LeftColumnGrid}" />
        </Style>
        <Style x:Key="InspectorRowSplitterPreviewStyle" TargetType="Control" BasedOn="{StaticResource RowSplitterPreviewStyle}">
            <Setter Property="Width" Value="{Binding ActualWidth, ElementName=InspectorGrid}" />
        </Style>
        <Style x:Key="HorizontalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Height" Value="{DynamicResource App.PanelGapSize}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ResizeDirection" Value="Rows" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <UniformGrid Rows="1"
                                         Columns="3"
                                         Width="24"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                <Ellipse Width="4" Height="4"
                                         Fill="{DynamicResource Brush.Text.Secondary}"
                                         Margin="{DynamicResource App.GripperDotMarginHorizontal}" />
                                <Ellipse Width="4" Height="4"
                                         Fill="{DynamicResource Brush.Text.Secondary}"
                                         Margin="{DynamicResource App.GripperDotMarginHorizontal}" />
                                <Ellipse Width="4" Height="4"
                                         Fill="{DynamicResource Brush.Text.Secondary}"
                                         Margin="{DynamicResource App.GripperDotMarginHorizontal}" />
                            </UniformGrid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TransformLogMonoTextStyle" TargetType="TextBlock" BasedOn="{StaticResource App.MonoTextStyle}" />
        <Style x:Key="TransformLogEntryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TransformLogMonoTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="FontSize" Value="11" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Surface.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="{DynamicResource App.PanelPadding}" />
        </Style>
        <Style x:Key="PanelBorderNoPaddingStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="HeaderBarBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="{DynamicResource App.PanelPadding}" />
        </Style>
    </Window.Resources>

    <Border Margin="{DynamicResource App.PanelMargin}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0"
                    Style="{StaticResource HeaderBarBorderStyle}"
                    Padding="{DynamicResource App.PanelPadding}"
                    Margin="{DynamicResource App.SectionSpacingBottom}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">Modulus</TextBlock>
                            <ComboBox Width="140"
                                      ItemsSource="{Binding Moduli}"
                                      SelectedItem="{Binding SelectedModulus}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">MIDI Out</TextBlock>
                            <ComboBox Width="220"
                                      ItemsSource="{Binding MidiDevices}"
                                      SelectedIndex="{Binding SelectedMidiDeviceIndex}"
                                      DisplayMemberPath="Name" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Test MIDI"
                                    Command="{Binding TestMidiCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Test Microtone"
                                    Command="{Binding TestMicrotoneCommand}"
                                    Margin="0,0,8,0" />
                            <Button x:Name="MidiDragButton"
                                    Content="Drag MIDI"
                                    ToolTip="Drag to export MIDI (.mid)"
                                    PreviewMouseLeftButtonDown="MidiDragButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MidiDragButton_PreviewMouseLeftButtonUp"
                                    PreviewMouseMove="MidiDragButton_PreviewMouseMove" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="1">
                        <Button Content="Play"
                                Command="{Binding PlayCommand}"
                                Click="Play_Click" />
                        <Button Content="Settings"
                                Click="Settings_Click"
                                Margin="8,0,0,0" />
                        <Button Content="MIDI Monitor"
                                Click="MidiMonitor_Click"
                                Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="MiddleColumn" Width="*" MinWidth="360" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition x:Name="WorkspaceColumn" Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition x:Name="InspectorColumn" Width="*" MinWidth="260" />
                </Grid.ColumnDefinitions>

            <!-- Left: Composites, Lenses, Transform Log -->
            <Grid Grid.Column="0" x:Name="LeftColumnGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="LeftTopRow" Height="*" />
                    <RowDefinition Height="{DynamicResource App.PanelGap}" />
                    <RowDefinition x:Name="LeftBottomRow" Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" x:Name="CompositesLensGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CompositesColumn" Width="*" MinWidth="20" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition x:Name="LensSelectorColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Composites -->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" x:Name="CompositesPanel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                    <StackPanel Margin="{DynamicResource App.SectionSpacingBottom}">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHeaderTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompositesCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="LayoutTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90" />
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="TextAlignment" Value="Center" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            Composites
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="{DynamicResource App.SectionSpacingTop}">
                            <ToggleButton x:Name="CompositesPinToggle"
                                          ToolTip="Pin the composites panel open"
                                          IsChecked="False"
                                          Margin="0,0,6,0"
                                          Checked="CompositesPinToggle_Checked"
                                          Unchecked="CompositesPinToggle_Unchecked">
                                <TextBlock FontFamily="Segoe MDL2 Assets">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE718;" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="False">
                                                    <Setter Property="Text" Value="&#xE77A;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ToggleButton>
                            <ComboBox x:Name="CompositeActionsSelector"
                                      Width="140"
                                      SelectedIndex="0"
                                      SelectionChanged="CompositeActions_SelectionChanged"
                                      DropDownOpened="CompositeActionsSelector_DropDownOpened"
                                      DropDownClosed="CompositeActionsSelector_DropDownClosed">
                                <ComboBoxItem Content="Actions" Tag="None" />
                                <ComboBoxItem Content="New" Tag="New" />
                                <ComboBoxItem Content="Duplicate" Tag="Duplicate" />
                                <ComboBoxItem Content="Rename" Tag="Rename" />
                                <ComboBoxItem Content="Delete" Tag="Delete" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Store.Composites}"
                             SelectedItem="{Binding Store.SelectedComposite}"
                             DisplayMemberPath="Title"
                             Margin="{DynamicResource App.SectionSpacingBottom}" />
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="{DynamicResource App.PanelGapSize}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  ShowsPreview="True" />

                    <!-- Lenses -->
                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="{DynamicResource App.SectionSpacingBottom}">
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" DockPanel.Dock="Left">Lenses</TextBlock>
                            </DockPanel>
                            <ListBox x:Name="LensSelectorList"
                                     Grid.Row="1"
                                     SelectionChanged="LensSelector_SelectionChanged">
                                <ListBoxItem Content="Initialization" Tag="Initialization" IsSelected="True" />
                                <ListBoxItem Content="IV Explorer" Tag="IVExplorer" />
                                <ListBoxItem Content="Focus Affine" Tag="FocusAffine" />
                                <ListBoxItem Content="ACDL" Tag="ACDL" />
                                <ListBoxItem Content="Gap -> PC" Tag="GapToPc" />
                                <ListBoxItem Content="Necklace Entry" Tag="NecklaceEntry" />
                                <ListBoxItem Content="Swirling Mists" Tag="SwirlingMists" />
                                <ListBoxItem Content="Interference Rhythm" Tag="InterferenceRhythm" />
                                <ListBoxItem Content="Test Lens" Tag="Test" />
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1"
                              Style="{StaticResource HorizontalGridSplitterStyle}"
                              PreviewStyle="{StaticResource LeftRowSplitterPreviewStyle}"
                              ShowsPreview="False" />

                <!-- Transform Log -->
                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="{DynamicResource App.SectionSpacingBottom}">
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" DockPanel.Dock="Left">
                                <TextBlock.Inlines>
                                    <Run Text="Transform Log" />
                                    <Run Text=" · "
                                         Foreground="{DynamicResource Brush.Text.Secondary}" />
                                    <Run Foreground="{DynamicResource Brush.Text.Secondary}"
                                         Text="{Binding Store.SelectedComposite.Title, TargetNullValue='(no composite selected)'}" />
                                </TextBlock.Inlines>
                            </TextBlock>
                        </DockPanel>
                        <DataGrid x:Name="TransformLogList"
                                  Grid.Row="1"
                                  ItemsSource="{Binding TransformLogView}"
                                  SelectedItem="{Binding SelectedLogEntry}"
                                  Loaded="TransformLogList_Loaded"
                                  SelectionChanged="TransformLog_SelectionChanged"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  Background="{DynamicResource Brush.Surface.Background}"
                                  RowBackground="{DynamicResource Brush.Surface.Background}"
                                  AlternatingRowBackground="{DynamicResource Brush.Surface.Background}"
                                  BorderThickness="1">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="TransformLogRow_PreviewMouseRightButtonDown" />
                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface.Background}" />
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Surface.Border}" />
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                    <Setter Property="SnapsToDevicePixels" Value="True" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Details..."
                                                          Command="{x:Static local:MainWindow.ShowTransformLogDetailsCommand}"
                                                          CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Selection.Fill}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Selection.Outline}" />
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True" />
                                                <Condition Property="Selector.IsSelectionActive" Value="False" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource Brush.Selection.Fill}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Selection.Outline}" />
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                        </MultiTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Canvas.GridLine}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Entry" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Grid.RowSpan="2"
                                                           Grid.Column="0"
                                                           Style="{StaticResource TransformLogEntryTextStyle}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="StepIndex">
                                                            <Binding />
                                                            <Binding Path="DataContext.Store" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <Grid Grid.Row="0" Grid.Column="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" MinWidth="16" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource TransformLogEntryTextStyle}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="Badges">
                                                                <Binding />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="2"
                                                               Style="{StaticResource TransformLogEntryTextStyle}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource TransformLogEntryConverter}"
                                                                          ConverterParameter="OpLabel">
                                                                <Binding />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="2"
                                                           Style="{StaticResource TransformLogEntryTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="OpSummary">
                                                            <Binding />
                                                            <Binding Path="DataContext.Store" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="{DynamicResource App.PanelGapSize}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <!-- Center: Workspace -->
            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid x:Name="WorkspacePanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl x:Name="WorkspaceHost" Content="" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="{DynamicResource App.PanelGapSize}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <!-- Right: Inspector -->
            <Grid Grid.Column="4" x:Name="InspectorGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="InspectorTopRow" Height="*" />
                    <RowDefinition Height="{DynamicResource App.PanelGap}" />
                    <RowDefinition x:Name="InspectorBottomRow" Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderNoPaddingStyle}"
                        Background="{DynamicResource Brush.Surface.Background}">
                    <views:InspectorView DataContext="{Binding Inspector}" />
                </Border>
                <GridSplitter Grid.Row="1"
                              Style="{StaticResource HorizontalGridSplitterStyle}"
                              PreviewStyle="{StaticResource InspectorRowSplitterPreviewStyle}"
                              ShowsPreview="False" />
                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <DockPanel Margin="{DynamicResource App.SectionSpacingBottom}">
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Workspace Preview" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <RadioButton Content="Chord"
                                             IsChecked="{Binding WorkspacePreviewNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Chord}"
                                             GroupName="WorkspacePreviewNotationMode"
                                             Margin="0,0,8,0" />
                                <RadioButton Content="Sequence"
                                             IsChecked="{Binding WorkspacePreviewNotationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sequence}"
                                             GroupName="WorkspacePreviewNotationMode" />
                                <Button Content="Play" Command="{Binding PlayWorkspacePreviewCommand}" Margin="12,0,0,0" />
                            </StackPanel>
                        </DockPanel>
                        <views:NotationView x:Name="WorkspaceNotation" Height="240" />
                        <ItemsControl ItemsSource="{Binding WorkspacePreview.Attributes}" Margin="{DynamicResource App.SectionSpacingTop}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Label, Mode=OneWay}"
                                                 Margin="0,0,6,0"
                                                 IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="False"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Value, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="False"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
