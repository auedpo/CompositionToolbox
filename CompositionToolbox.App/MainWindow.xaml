<Window x:Class="CompositionToolbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CompositionToolbox.App.ViewModels"
        xmlns:views="clr-namespace:CompositionToolbox.App.Views"
        xmlns:converters="clr-namespace:CompositionToolbox.App.Converters"
        xmlns:local="clr-namespace:CompositionToolbox.App"
        Title="Composition Toolbox" Height="720" Width="1100"
        FontFamily="Segoe UI"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.ShowTransformLogDetailsCommand}"
                        Executed="TransformLogDetails_Executed"
                        CanExecute="TransformLogDetails_CanExecute" />
    </Window.CommandBindings>

    <Window.Resources>
        <converters:TransformLogEntryConverter x:Key="TransformLogEntryConverter" />
        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>
        <Style x:Key="TransformLogMonoTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas,Cascadia Mono,Courier New" />
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundChromeLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="PanelBorderNoPaddingStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="HeaderBarBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding OpenPresetPickerCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Margin="8" Style="{StaticResource HeaderBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">Modulus</TextBlock>
                        <ComboBox Width="140"
                                  ItemsSource="{Binding Moduli}"
                                  SelectedItem="{Binding SelectedModulus}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">MIDI Out</TextBlock>
                        <ComboBox Width="220"
                                  ItemsSource="{Binding MidiDevices}"
                                  SelectedIndex="{Binding SelectedMidiDeviceIndex}"
                                  DisplayMemberPath="Name" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Test MIDI"
                                Command="{Binding TestMidiCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Test Microtone"
                                Command="{Binding TestMicrotoneCommand}"
                                Margin="0,0,8,0" />
                        <Button x:Name="MidiDragButton"
                                Content="Drag MIDI"
                                ToolTip="Drag to export MIDI (.mid)"
                                PreviewMouseLeftButtonDown="MidiDragButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="MidiDragButton_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="MidiDragButton_PreviewMouseMove" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="1">
                    <Button Content="Play"
                            Command="{Binding PlayCommand}"
                            Click="Play_Click" />
                    <Button Content="Settings"
                            Click="Settings_Click"
                            Margin="8,0,0,0" />
                    <Button Content="MIDI Monitor"
                            Click="MidiMonitor_Click"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="CompositesColumn" Width="*" MinWidth="220" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="InspectorColumn" Width="*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <!-- Left: Composites -->
            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" DockPanel.Dock="Left">Composites</TextBlock>
                    </DockPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Store.Composites}"
                             SelectedItem="{Binding Store.SelectedComposite}"
                             DisplayMemberPath="Title"
                             Margin="0,0,0,8" />
                    <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Left">
                        <Button Content="New" Command="{Binding NewCompositeCommand}" Margin="0,0,0,6" />
                        <Button Content="Duplicate" Command="{Binding DuplicateCompositeCommand}" Margin="0,0,0,6" />
                        <Button Content="Rename" Command="{Binding RenameCompositeCommand}" Margin="0,0,0,6" />
                        <Button Content="Delete" Command="{Binding DeleteCompositeCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowsPreview="True" />

            <!-- Middle column: Lenses, Transform Log, Workspace Preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LensSelectorColumn" Width="*" MinWidth="170" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition x:Name="TransformLogColumn" Width="*" MinWidth="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Lens Selector -->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" DockPanel.Dock="Left">Lenses</TextBlock>
                            </DockPanel>
                            <ListBox x:Name="LensSelectorList"
                                     Grid.Row="1"
                                     SelectionChanged="LensSelector_SelectionChanged">
                                <ListBoxItem Content="Initialization" Tag="Initialization" IsSelected="True" />
                                <ListBoxItem Content="IV Explorer" Tag="IVExplorer" />
                                <ListBoxItem Content="Focus Affine" Tag="FocusAffine" />
                                <ListBoxItem Content="ACDL" Tag="ACDL" />
                                <ListBoxItem Content="Gap -> PC" Tag="GapToPc" />
                                <ListBoxItem Content="Test Lens" Tag="Test" />
                            </ListBox>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowsPreview="True" />

                    <!-- Transform Log -->
                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" DockPanel.Dock="Left">Transform Log</TextBlock>
                            </DockPanel>
                            <DataGrid x:Name="TransformLogList"
                                      Grid.Row="1"
                                      ItemsSource="{Binding Store.CurrentLogEntries}"
                                      SelectedItem="{Binding SelectedLogEntry}"
                                      Loaded="TransformLogList_Loaded"
                                      SelectionChanged="TransformLog_SelectionChanged"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      RowHeight="24"
                                      Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                                      RowBackground="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                                      AlternatingRowBackground="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                                      BorderThickness="1">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="TransformLogRow_PreviewMouseRightButtonDown" />
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="Details..."
                                                              Command="{x:Static local:MainWindow.ShowTransformLogDetailsCommand}"
                                                              CommandParameter="{Binding}" />
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Step" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource TransformLogMonoTextStyle}">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="StepIndex">
                                                            <Binding />
                                                            <Binding Path="DataContext.Store" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Op" Width="120" Binding="{Binding Op}" ElementStyle="{StaticResource TransformLogMonoTextStyle}" />
                                    <DataGridTemplateColumn Header="Badge" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource TransformLogMonoTextStyle}" HorizontalAlignment="Right">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="Badges">
                                                            <Binding />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PitchList" Width="300">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource TransformLogMonoTextStyle}" TextWrapping="Wrap">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource TransformLogEntryConverter}" ConverterParameter="PitchListValue">
                                                            <Binding />
                                                            <Binding Path="DataContext.Store" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Workspace Preview -->
                <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="0,6,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Workspace Preview" DockPanel.Dock="Left" />
                            <Button Content="Play" Command="{Binding PlayWorkspacePreviewCommand}" DockPanel.Dock="Right" />
                        </DockPanel>
                        <views:NotationView x:Name="WorkspaceNotation" Height="240" />
                        <ItemsControl ItemsSource="{Binding WorkspacePreview.Attributes}" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Label, Mode=OneWay}"
                                                 Margin="0,0,6,0"
                                                 IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="False"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Value, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="False"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowsPreview="True" />

            <!-- Center: Workspace -->
            <Border Grid.Column="4" Style="{StaticResource PanelBorderStyle}">
                <Grid x:Name="WorkspacePanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl x:Name="WorkspaceHost" Content="" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="5" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowsPreview="True" />

            <!-- Right: Inspector -->
            <Border Grid.Column="6"
                    Style="{StaticResource PanelBorderNoPaddingStyle}"
                    Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">
                <views:InspectorView DataContext="{Binding Inspector}" />
            </Border>
        </Grid>
    </Grid>
</Window>
